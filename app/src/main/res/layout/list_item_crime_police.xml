<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    android:background="#FFEBEE">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/crime_solved_image"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_solved_handcuff"
            android:contentDescription="Crime solved"
            android:visibility="gone" />

        <TextView
            android:id="@+id/crime_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toLeftOf="@id/crime_solved_image"
            android:text="Crime title"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#D32F2F"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/crime_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/crime_title"
            android:layout_toLeftOf="@id/crime_solved_image"
            android:text="Crime date"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/contact_police_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/crime_date"
            android:layout_alignParentLeft="true"
            android:text="Contact Police"
            android:textSize="12sp"
            android:background="#D32F2F"
            android:textColor="#FFFFFF"
            android:padding="8dp"
            android:layout_marginRight="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/crime_date"
            android:layout_toRightOf="@id/contact_police_button"
            android:layout_centerVertical="true"
            android:text="🚨 Serious Crime"
            android:textSize="12sp"
            android:textColor="#D32F2F"
            android:textStyle="bold" />

    </RelativeLayout>

</androidx.cardview.widget.CardView>
